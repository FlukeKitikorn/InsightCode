PORT=4000
NODE_ENV=development

# PostgreSQL (จาก docker-compose.yml)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# JWT Secrets (เปลี่ยนใน production!)
JWT_ACCESS_SECRET="replace-with-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-strong-refresh-secret"

# Token Expiry
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Token for internal judge
INTERNAL_JUDGE_TOKEN="your_internal_judge_token_here"

# Admin secret-key
ADMIN_SECRET_CODE="100"

# Redis for BullMQ / queues
REDIS_URL="redis://localhost:6379"

# OpenRouter (สำหรับ Chat / LLM)
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-4o-mini"
