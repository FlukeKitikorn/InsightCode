generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/client"
}
datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(255)
  passwordHash String        @map("password_hash") @db.Text
  role         String        @default("USER") @db.VarChar(20)
  fullName     String?       @map("full_name") @db.VarChar(255)
  avatarUrl    String?       @map("avatar_url") @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")

  submissions       Submission[]
  refreshTokens     RefreshToken[]
  announcementReads AnnouncementRead[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.Text
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revoked   Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum ProblemDifficulty {
  EASY
  MEDIUM
  HARD
}

model Problem {
  id          String            @id @default(uuid()) @db.Uuid
  title       String            @db.VarChar(255)
  description String            @db.Text
  difficulty  ProblemDifficulty @default(EASY)
  createdAt   DateTime          @default(now()) @map("created_at")

  testCases   TestCase[]
  submissions Submission[]

  @@map("problems")
}

model TestCase {
  id             Int      @id @default(autoincrement())
  problemId      String   @map("problem_id") @db.Uuid
  inputData      String?  @map("input_data") @db.Text
  expectedOutput String?  @map("expected_output") @db.Text
  isHidden       Boolean  @default(true) @map("is_hidden")

  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

model Submission {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String?     @map("user_id") @db.Uuid
  problemId     String?     @map("problem_id") @db.Uuid
  code          String?     @db.Text
  language      String?     @db.VarChar(20)
  status        String      @default("pending") @db.VarChar(30)
  executionTime Float?      @map("execution_time")
  memoryUsed    Float?      @map("memory_used")
  createdAt     DateTime    @default(now()) @map("created_at")

  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  problem       Problem?    @relation(fields: [problemId], references: [id])
  aiFeedback    AiFeedback?

  @@map("submissions")
}

model AiFeedback {
  id           Int        @id @default(autoincrement())
  submissionId String     @unique @map("submission_id") @db.Uuid
  analysisText String?    @map("analysis_text") @db.Text
  qualityScore Float?     @map("quality_score")
  createdAt    DateTime   @default(now()) @map("created_at")

  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("ai_feedback")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  body      String   @db.Text
  type      String   @default("info") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  readBy AnnouncementRead[]

  @@map("announcements")
}

model AnnouncementRead {
  userId         String   @map("user_id") @db.Uuid
  announcementId Int      @map("announcement_id")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@id([userId, announcementId])
  @@map("announcement_reads")
}
