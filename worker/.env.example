# Backend server
PORT=4000

# PostgreSQL (Prisma)
# รูปแบบ: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Redis for BullMQ / queues
REDIS_URL="redis://localhost:6379"
# Connect to redisinsight redis://redis:6379

BACKEND_URL="http://localhost:4000"         # หรือ URL จริงของ backend
INTERNAL_JUDGE_TOKEN="your_internal_judge_token_here"  # ต้องตรงกับใน Backend/.env

# JWT secrets (replace with strong random strings in your real .env)
ACCESS_TOKEN_SECRET="replace-with-strong-access-secret"
REFRESH_TOKEN_SECRET="replace-with-strong-refresh-secret"

# Admin special code (already used by auth.controller)
ADMIN_SECRET_CODE="100"

# OpenRouter / LLM integration
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-4o"            # หรือโมเดลอื่น เช่น anthropic/claude-3-haiku